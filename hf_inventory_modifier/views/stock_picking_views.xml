<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Progress badge on list view -->
    <record id="hf_inventory_modifier_view_picking_tree_inherit_progress" model="ir.ui.view">
        <field name="name">hf.inventory.modifier.stock.picking.list.progress</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='state']" position="before">
                <field name="hf_progress_state" widget="badge" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Progress statusbar on form view -->
    <record id="hf_inventory_modifier_view_picking_form_inherit_progress" model="ir.ui.view">
        <field name="name">hf.inventory.modifier.stock.picking.form.progress</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_assign']" position="after">
                <button name="action_hf_set_receipt_dispatched"
                        string="Set as Dispatched"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'incoming' or state != 'assigned' or hf_progress_state != 'processed'"/>
                <button name="action_hf_process_receipt"
                        string="Process Receipt"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'incoming' or state == 'done' or hf_progress_state != 'dispatched'"/>
                <button name="action_hf_internal_set_dispatched"
                        string="Set as Dispatched"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'internal' or state != 'assigned' or hf_progress_state != 'processed'"/>
                <button name="action_hf_ship_goods"
                        string="Ship Goods"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'internal' or state != 'assigned' or hf_progress_state != 'dispatched' or hf_transit_receipt_picking_id"/>
                <button name="action_hf_confirm_received"
                        string="Confirm Received"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'internal' or hf_progress_state == 'delivered' or (not hf_transit_receipt_picking_id and not hf_transit_source_picking_id)"/>
                <button name="action_hf_out_set_dispatched"
                        string="Set as Dispatched"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'outgoing' or state != 'assigned' or hf_progress_state != 'processed'"/>
                <button name="action_hf_out_for_delivery"
                        string="Out for Delivery"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'outgoing' or state == 'done' or hf_progress_state == 'delivered'"/>
                <button name="action_hf_mark_delivered"
                        string="Mark Delivered"
                        type="object"
                        class="oe_highlight"
                        invisible="picking_type_code != 'outgoing' or state != 'done' or hf_progress_state == 'delivered'"/>
            </xpath>
            <xpath expr="//field[@name='state'][@widget='statusbar'][@invisible=&quot;picking_type_code != 'incoming'&quot;]" position="replace">
                <field name="state"
                       widget="statusbar"
                       statusbar_visible="draft,assigned,done"/>
            </xpath>
            <xpath expr="//field[@name='state'][@widget='statusbar'][@invisible=&quot;picking_type_code == 'incoming'&quot;]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
             <xpath expr="//field[@name='state'][@widget='statusbar']" position="after">
                <field name="hf_progress_state"
                       widget="statusbar" readonly="1"
                       statusbar_visible="placed,processed,dispatched,delivered"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <field name="hf_signature_bypassed" invisible="1"/>
                <field name="hf_transit_source_picking_id" invisible="1"/>
                <field name="hf_transit_receipt_picking_id" invisible="1"/>
                <field name="hf_final_location_dest_id" invisible="1"/>
                <field name="hf_placed_at" invisible="1"/>
                <field name="hf_processed_at" invisible="1"/>
                <field name="hf_dispatched_at" invisible="1"/>
                <field name="hf_delivered_at" invisible="1"/>
            </xpath>

            <xpath expr="//button[@name='button_validate' and contains(@class, 'oe_highlight')]" position="attributes">
                <attribute name="string">Set as Delivered</attribute>
                <attribute name="invisible">(state == 'done' and hf_progress_state == 'delivered') or picking_type_code != 'incoming'</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate' and contains(@class, 'o_btn_validate')]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="string">Validate</attribute>
            </xpath>
        </field>
    </record>

    <!-- Progress badge as search field, filter and group-by -->
    <record id="hf_inventory_modifier_view_picking_search_inherit_progress" model="ir.ui.view">
        <field name="name">hf.inventory.modifier.stock.picking.search.progress</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_internal_search"/>
        <field name="arch" type="xml">
            <!-- Searchable field -->
            <xpath expr="//search/field[@name='picking_type_id']" position="after">
                <field name="hf_progress_state"/>
            </xpath>

            <!-- Filters: one per progress stage -->
            <xpath expr="//filter[@name='backorder']" position="after">
                <separator/>
                <filter name="hf_progress_placed"
                        string="Placed"
                        domain="[('hf_progress_state', '=', 'placed')]"/>
                <filter name="hf_progress_processed"
                        string="Processed"
                        domain="[('hf_progress_state', '=', 'processed')]"/>
                <filter name="hf_progress_dispatched"
                        string="Dispatched"
                        domain="[('hf_progress_state', '=', 'dispatched')]"/>
                <filter name="hf_progress_delivered"
                        string="Delivered"
                        domain="[('hf_progress_state', '=', 'delivered')]"/>
            </xpath>

            <!-- Group-by entry alongside existing groups -->
            <xpath expr="//filter[@name='status']" position="after">
                <filter name="hf_progress_group"
                        string="Progress State"
                        context="{'group_by': 'hf_progress_state'}"/>
            </xpath>
        </field>
    </record>

</odoo>
