<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- FOTS Manager Group: full access to FOTS ops + invoicing + stock -->
        <record id="group_fots_manager" model="res.groups">
            <field name="name">FOTS Manager</field>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman_all_leads')),
                                             (4, ref('stock.group_stock_user')),
                                             (4, ref('account.group_account_invoice'))]"/>
        </record>

        <!-- FOTS User Group: salesman + stock user (no accounting) -->
        <record id="group_fots_user" model="res.groups">
            <field name="name">FOTS User</field>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman')),
                                             (4, ref('stock.group_stock_user'))]"/>
        </record>
        
        <!-- Record Rules -->
        
        <!-- Agent: Managers see all, users see only their own -->
        <record id="fots_agent_manager_rule" model="ir.rule">
            <field name="name">FOTS Agent: Manager sees all</field>
            <field name="model_id" ref="model_fots_agent"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_fots_manager'))]"/>
        </record>
        
        <record id="fots_agent_user_rule" model="ir.rule">
            <field name="name">FOTS Agent: User sees own profile</field>
            <field name="model_id" ref="model_fots_agent"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_fots_user'))]"/>
        </record>
        
        
    </data>
</odoo>
