<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_loyalty_delegation" model="ir.ui.view">
        <field name="name">res.users.form.loyalty.delegation</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Loyalty Delegation" name="loyalty_delegation">
                    <div class="alert alert-info" role="alert"
                         invisible="not loyalty_delegation_active">
                        Delegation is currently active — loyalty approval levels route to the delegate.
                    </div>
                    <group>
                        <field name="loyalty_delegate_id"/>
                        <field name="loyalty_delegate_from"/>
                        <field name="loyalty_delegate_to"/>
                        <field name="loyalty_delegation_active" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
