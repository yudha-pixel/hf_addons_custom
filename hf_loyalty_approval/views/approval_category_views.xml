<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="loyalty_approval_category_view_list" model="ir.ui.view">
        <field name="name">loyalty.approval.category.list</field>
        <field name="model">loyalty.approval.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="level_count"/>
                <field name="min_approval"/>
                <field name="company_id" optional="show" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="loyalty_approval_category_view_form" model="ir.ui.view">
        <field name="name">loyalty.approval.category.form</field>
        <field name="model">loyalty.approval.category</field>
        <field name="arch" type="xml">
            <form string="Loyalty Approval Category">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Loyalty — Standard"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="min_approval"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="level_count" readonly="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Internal note about when this category applies..."/>
                    <notebook>
                        <page string="Levels" name="levels">
                            <field name="approver_line_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="level_name"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="group_id"/>
                                    <field name="min_approvals"/>
                                    <field name="required"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_loyalty_approval_category" model="ir.actions.act_window">
        <field name="name">Approval Categories</field>
        <field name="res_model">loyalty.approval.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
