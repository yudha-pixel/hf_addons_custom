<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 
        Access Restriction Rules for Field Sales Agents & Student Ambassadors
        These rules ensure salespersons can only see their own customers and sales orders
        -->
        
        <!-- Rule: Salesperson can only see their own Sales Orders -->
        <record id="rule_sale_order_personal" model="ir.rule">
            <field name="name">Personal Sales Orders Only</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- Rule: Salesperson can only see their own Customers -->
        <record id="rule_partner_personal" model="ir.rule">
            <field name="name">Personal Customers Only</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- 
        NOTE: Sales Managers should still see all records.
        The above rules only apply to group_sale_salesman.
        Sales Managers (group_sale_manager) are not affected by these rules.
        -->
    </data>
</odoo>
