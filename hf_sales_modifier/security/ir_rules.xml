<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="rule_account_move_marketing_customer_invoices" model="ir.rule">
        <field name="name">Marketing: Customer Invoices Only</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="domain_force">[('move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt'))]</field>
        <field name="groups" eval="[(4, ref('hf_sales_modifier.group_head_marketing_readonly'))]"/>
    </record>

    <record id="rule_account_move_line_marketing_customer_invoices" model="ir.rule">
        <field name="name">Marketing: Customer Invoice Lines Only</field>
        <field name="model_id" ref="account.model_account_move_line"/>
        <field name="domain_force">[('move_id.move_type', 'in', ('out_invoice', 'out_refund', 'out_receipt'))]</field>
        <field name="groups" eval="[(4, ref('hf_sales_modifier.group_head_marketing_readonly'))]"/>
    </record>

</odoo>
