<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hf_mailbox_label_list" model="ir.ui.view">
        <field name="name">hf.mailbox.label.list</field>
        <field name="model">hf.mailbox.label</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="user_id"/>
                <field name="system_key" readonly="1"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_hf_mailbox_label_form" model="ir.ui.view">
        <field name="name">hf.mailbox.label.form</field>
        <field name="model">hf.mailbox.label</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                        <field name="sequence"/>
                        <field name="user_id"/>
                        <field name="active"/>
                        <field name="system_key" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hf_mailbox_label" model="ir.actions.act_window">
        <field name="name">Labels</field>
        <field name="res_model">hf.mailbox.label</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
