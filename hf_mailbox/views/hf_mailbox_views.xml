<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Thread list / form (debug / backend fallback) -->
    <record id="view_hf_mailbox_thread_list" model="ir.ui.view">
        <field name="name">hf.mailbox.thread.list</field>
        <field name="model">hf.mailbox.thread</field>
        <field name="arch" type="xml">
            <list decoration-bf="last_direction == 'incoming'"
                  decoration-muted="state == 'done'"
                  decoration-warning="state == 'waiting'">
                <field name="last_message_date"/>
                <field name="name"/>
                <field name="last_author_id"/>
                <field name="last_direction"/>
                <field name="message_count"/>
                <field name="state"/>
                <field name="label_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="source_model"/>
            </list>
        </field>
    </record>

    <record id="view_hf_mailbox_thread_form" model="ir.ui.view">
        <field name="name">hf.mailbox.thread.form</field>
        <field name="model">hf.mailbox.thread</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_waiting" type="object" string="Mark Waiting"
                            invisible="state != 'open'"/>
                    <button name="action_mark_done" type="object" string="Mark Done"
                            invisible="state == 'done'" class="btn-primary"/>
                    <button name="action_reopen" type="object" string="Reopen"
                            invisible="state != 'done'"/>
                    <button name="action_open_source" type="object" string="Open Source"
                            invisible="not source_model"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,waiting,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="source_model"/>
                            <field name="source_res_id"/>
                            <field name="last_message_date"/>
                            <field name="last_direction"/>
                        </group>
                        <group>
                            <field name="label_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="followup_due_date"/>
                            <field name="followup_done"/>
                            <field name="participant_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Messages">
                            <field name="message_ids" readonly="1">
                                <list decoration-info="direction == 'incoming'"
                                      decoration-muted="direction == 'internal'">
                                    <field name="chain_index"/>
                                    <field name="date"/>
                                    <field name="author_id"/>
                                    <field name="direction"/>
                                    <field name="subject"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hf_mailbox_thread_search" model="ir.ui.view">
        <field name="name">hf.mailbox.thread.search</field>
        <field name="model">hf.mailbox.thread</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="participant_ids"/>
                <field name="label_ids"/>
                <field name="source_model"/>
                <filter name="open" string="Open" domain="[('state','=','open')]"/>
                <filter name="waiting" string="Waiting Reply" domain="[('state','=','waiting')]"/>
                <filter name="done" string="Done" domain="[('state','=','done')]"/>
                <separator/>
                <filter name="incoming" string="Last Incoming"
                        domain="[('last_direction','=','incoming')]"/>
                <filter name="outgoing" string="Last Outgoing"
                        domain="[('last_direction','=','outgoing')]"/>
                <group>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_source" string="Source Model" context="{'group_by': 'source_model'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hf_mailbox_thread" model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">hf.mailbox.thread</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hf_mailbox_thread_search"/>
    </record>

    <!-- Owl client action -->
    <record id="action_hf_mailbox_client" model="ir.actions.client">
        <field name="name">Mailbox</field>
        <field name="tag">hf_mailbox.view</field>
    </record>

</odoo>
